# OpenAI API key — required for agent LLM calls
OPENAI_API_KEY=sk-your-key-here

# OpenAI model — gpt-4o-mini is the default (cost-effective)
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL connection URL with asyncpg driver (PostGIS required)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexus_twin

# Redis connection URL — used by Celery broker, backend, and Pub/Sub
REDIS_URL=redis://localhost:6379

# FastAPI server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Vite env vars — backend REST API base URL
VITE_API_URL=http://localhost:8000

# Frontend Vite env vars — Martin vector tile server
VITE_TILE_SERVER_URL=http://localhost:3001

# Tick interval in seconds (minimum 10 — adjustable via dashboard)
TICK_INTERVAL_SECONDS=10

# Maximum concurrent OpenAI API calls (asyncio.Semaphore)
MAX_AGENT_WORKERS=4

# Valhalla routing engine base URL
VALHALLA_URL=http://localhost:8002

# Path to the OSM PBF extract used by Valhalla
OSM_DATA_PATH=./geo/data/sudeste-latest.osm.pbf

# Path to the PMTiles file served by Martin
PMTILES_PATH=./geo/data/sudeste.pmtiles

# Observability (Langfuse) — optional
# Leave blank to disable instrumentation; the system runs normally without it.
# After the first `docker compose up`, open http://localhost:3100, create a
# user, open the `NexusTwin` project, go to Settings > API Keys, and paste
# public_key / secret_key below.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100
